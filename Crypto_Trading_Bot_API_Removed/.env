# Kraken API Credentials
KRAKEN_API_KEY=ENTERKEYHERE
KRAKEN_API_SECRET=ENTERSECRETHERE

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=ENTERTOKENHERE
TELEGRAM_CHAT_ID=ENTERCHATIDHERE

# Trading Configuration
TRADING_PAIRS=BTC/USD,ETH/USD,SOL/USD
RISK_PER_TRADE_PCT=4.0        # Percentage of total balance risked per trade
MAX_POSITION_PCT=15.0          # Maximum % of balance invested in a single trade
MAX_DAILY_LOSS_PCT=15.0        # Stop trading if daily loss exceeds this %
MAX_OPEN_POSITIONS=3           # Maximum concurrent open positions
MAX_POSITION_HOURS=24.0         # Force-close position after this many hours
TRAIL_ACTIVATION_PCT=50.0      # Activate trailing stop when price is 50% of the way to TP
TRAIL_DISTANCE_PCT=0.8         # Trail stop 0.8% below the highest price seen
DRY_RUN=false                   # Set to false to enable live trading

# Strategy Selection (true/false to enable each)
STRATEGY_SCALPING=true
STRATEGY_BREAKOUT=true
STRATEGY_RANGE_TRADING=true
STRATEGY_MA_TREND=true

# Logging
LOG_LEVEL=INFO
